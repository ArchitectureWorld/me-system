{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://me-system.local/schemas/graph-node/0.1",
  "title": "GraphNode",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "id", "graph", "type", "label", "properties",
    "authority", "confirmation_status", "status", "valid_from", "valid_to",
    "sensitivity", "source_refs"
  ],
  "properties": {
    "schema_version": {"const": "graph-node/0.1"},
    "id": {"type": "string", "minLength": 3},
    "graph": {"enum": ["me_brain", "me_who"]},
    "type": {"type": "string", "minLength": 1},
    "label": {"type": "string", "minLength": 1},
    "properties": {"type": "object"},
    "authority": {"enum": ["canonical", "human_confirmed", "rule_confirmed", "candidate", "inference", "raw_evidence"]},
    "confirmation_status": {"enum": ["human_confirmed", "rule_confirmed", "pending", "rejected", "superseded", "observed", "inferred"]},
    "status": {"enum": ["current", "historical", "superseded", "future_planned", "unknown"]},
    "valid_from": {"type": ["string", "null"], "format": "date-time"},
    "valid_to": {"type": ["string", "null"], "format": "date-time"},
    "sensitivity": {"enum": ["public", "project_private", "personal_private", "restricted"]},
    "source_refs": {"type": "array", "items": {"$ref": "#/$defs/evidenceRef"}}
  },
  "$defs": {
    "evidenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "source_anchor"],
      "properties": {
        "source_id": {"type": "string", "minLength": 1},
        "document_id": {"type": ["string", "null"]},
        "version_id": {"type": ["string", "null"]},
        "content_fragment_id": {"type": ["string", "null"]},
        "source_anchor": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "value"],
          "properties": {
            "type": {"type": "string", "minLength": 1},
            "value": {"type": "object"}
          }
        }
      }
    }
  }
}
