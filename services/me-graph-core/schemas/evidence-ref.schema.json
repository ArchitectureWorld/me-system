{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://me-system.local/schemas/evidence-ref/0.1",
  "title": "EvidenceRef",
  "type": "object",
  "additionalProperties": false,
  "required": ["source_id", "source_anchor"],
  "properties": {
    "source_id": {"type": "string", "minLength": 1},
    "document_id": {"type": ["string", "null"]},
    "version_id": {"type": ["string", "null"]},
    "content_fragment_id": {"type": ["string", "null"]},
    "source_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {
        "type": {"type": "string", "minLength": 1},
        "value": {"type": "object"}
      }
    }
  }
}
