{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://me-system.local/schemas/graph-slice/0.1",
  "title": "GraphSlice",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "slice_id", "graph", "as_of_time", "root_ids", "summary",
    "nodes", "edges", "evidence_handles", "excluded", "truncated"
  ],
  "properties": {
    "schema_version": {"const": "graph-slice/0.1"},
    "slice_id": {"type": "string", "minLength": 3},
    "graph": {"enum": ["me_brain", "me_who", "bridge"]},
    "as_of_time": {"type": ["string", "null"], "format": "date-time"},
    "root_ids": {"type": "array", "items": {"type": "string"}},
    "summary": {"type": "string"},
    "nodes": {"type": "array", "items": {"type": "object"}},
    "edges": {"type": "array", "items": {"type": "object"}},
    "evidence_handles": {"type": "array", "items": {"$ref": "#/$defs/evidenceRef"}},
    "excluded": {
      "type": "object",
      "additionalProperties": false,
      "required": ["superseded", "unauthorized"],
      "properties": {
        "superseded": {"type": "array", "items": {"type": "string"}},
        "unauthorized": {"type": "array", "items": {"type": "string"}}
      }
    },
    "truncated": {"type": "boolean"}
  },
  "$defs": {
    "evidenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "source_anchor"],
      "properties": {
        "source_id": {"type": "string", "minLength": 1},
        "document_id": {"type": ["string", "null"]},
        "version_id": {"type": ["string", "null"]},
        "content_fragment_id": {"type": ["string", "null"]},
        "source_anchor": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "value"],
          "properties": {
            "type": {"type": "string", "minLength": 1},
            "value": {"type": "object"}
          }
        }
      }
    }
  }
}
