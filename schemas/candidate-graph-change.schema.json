{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://me-system.local/schemas/candidate-graph-change/0.1",
  "title": "CandidateGraphChange",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "change_id", "target_graph", "operation", "submitted_by",
    "reason", "evidence_refs", "payload", "review_status"
  ],
  "properties": {
    "schema_version": {"const": "candidate-graph-change/0.1"},
    "change_id": {"type": "string", "minLength": 3},
    "target_graph": {"enum": ["me_brain", "me_who", "bridge"]},
    "operation": {"enum": ["add_node", "add_edge"]},
    "submitted_by": {"type": "string", "minLength": 1},
    "reason": {"type": "string", "minLength": 1},
    "evidence_refs": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/evidenceRef"}},
    "payload": {"type": "object", "minProperties": 1},
    "review_status": {"enum": ["pending", "approved", "rejected"]},
    "reviewed_by": {"type": ["string", "null"]},
    "review_reason": {"type": ["string", "null"]}
  },
  "$defs": {
    "evidenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "source_anchor"],
      "properties": {
        "source_id": {"type": "string", "minLength": 1},
        "document_id": {"type": ["string", "null"]},
        "version_id": {"type": ["string", "null"]},
        "content_fragment_id": {"type": ["string", "null"]},
        "source_anchor": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "value"],
          "properties": {
            "type": {"type": "string", "minLength": 1},
            "value": {"type": "object"}
          }
        }
      }
    }
  }
}
